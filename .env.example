# SignalConvert ortam değişkenleri
# Bu dosyayı .env olarak kopyala ve değerleri güncelle

# Web UI admin şifresi (dashboard ve setup sayfası için)
ADMIN_PASSWORD=change-me-please

# Gizli anahtar (session için)
SECRET_KEY=change-this-to-a-random-long-string

# Uygulama URL'i (Coolify'da kendi domain'in, webhook URL üretimi için)
PUBLIC_BASE_URL=http://localhost:5000

# SQLite DB yolu (Coolify volume'a bağla)
DATABASE_URL=sqlite:///data/signalconvert.db

# Kart PNG'lerinin kaydedileceği klasör
IMAGES_DIR=data/images

# Kartlarda sağ üst/alt köşede görünen marka ismi
BRAND_NAME=Alfa Trade Hunter

# Zaman dilimi (kart footer tarihi için)
TZ=Europe/Istanbul
